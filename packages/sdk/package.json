{
  "name": "@post2all/sdk",
  "version": "0.2.0",
  "private": false,
  "description": "TypeScript SDK for post2all public API",
  "author": "post2all",
  "license": "MIT",
  "homepage": "https://www.post2all.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/zexahq/post2all-sdk"
  },
  "bugs": {
    "url": "https://github.com/zexahq/post2all-sdk/issues"
  },
  "keywords": [
    "post2all",
    "sdk",
    "social-media",
    "api"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
